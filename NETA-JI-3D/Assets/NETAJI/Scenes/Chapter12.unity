  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NetaJi.Prototype.MissionController
  missionTitle: Zila Sangathan
  completionTitle: CHAPTER 12 COMPLETE
  completionMessage: Prayagraj district network ab verified candidates, issue desks
    and public rules par khada hai. Multi-seat journey ready hai.
  chapterNumber: 12
  nextChapterScene: 
  introTitle: CHAPTER 12 / ZILA SANGATHAN
  introMessage: 'Ek seat se aage badho: clean candidates aur disciplined district
    network earn karo.'
  objectives:
  - {fileID: 1429325144}
  - {fileID: 2050593215}
  - {fileID: 422621892}
  - {fileID: 58137859}
  - {fileID: 2143920051}
  - {fileID: 1363134618}
  - {fileID: 471881028}
  - {fileID: 490794187}
  - {fileID: 916978739}
  - {fileID: 174217478}
  - {fileID: 1232656486}
  - {fileID: 960392414}
  objectiveLabels:
  - Independent auditor se MLA record aur expansion eligibility verify karein
  - Six fictional zones ka comparable public-issue baseline lock karein
  - Independent criteria se fictional candidate disclosures and service record vet
    karein
  - Shanti ke saath women-youth public leadership cohort train karein
  - Rural blocks ke issue desks aur accountable coordinators connect karein
  - Urban zones ko shared complaint and volunteer dashboard par jodein
  - Open local primary ya centralized closed appointment mein decision lein
  - Zone-wise donations and organization expenses ka public audit close karein
  - Fictional candidate rumour ko source-backed district correction se answer karein
  - All zones ka evidence-led public convention and objection session complete karein
  - Candidate, consent, funding and anti-hate compliance checklist lock karein
  - Independent panel par computed district expansion score dekhein
  milestoneSteps: 03000000070000000a000000
  milestoneTitles:
  - DISTRICT BASELINE LOCKED
  - RURAL-URBAN NETWORK ACTIVE
  - CANDIDATE SYSTEM AUDITED
  milestoneMessages:
  - MLA record, issue map and candidate criteria verified. Ab leadership bench and
    zone coordinators build karo.
  - Leadership cohort, rural-urban desks and selection decision complete. Funding
    and information discipline next hai.
  - Funding, fact-check and public convention complete. Final compliance district
    readiness decide karega.
