  missionTitle: Zila Sangathan
  completionTitle: CHAPTER 12 COMPLETE
  completionMessage: Prayagraj district network ab verified candidates, issue desks
    and public rules par khada hai. Multi-seat journey ready hai.
  chapterNumber: 12
  nextChapterScene: 
  introTitle: CHAPTER 12 / ZILA SANGATHAN
  introMessage: 'Ek seat se aage badho: clean candidates aur disciplined district
    network earn karo.'
  objectives:
  - {fileID: 455921656}
  - {fileID: 599365209}
  - {fileID: 1845047796}
  - {fileID: 987055498}
  - {fileID: 841073200}
