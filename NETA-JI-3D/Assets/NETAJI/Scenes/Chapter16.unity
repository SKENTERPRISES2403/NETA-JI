  completionTitle: CHAPTER 16 COMPLETE
  completionMessage: Independent 100-day audit pass hua. State reform programme full
    term ke liye approved hai.
  chapterNumber: 16
  nextChapterScene: 
  introTitle: CHAPTER 16 / CM KE PEHLE 100 DIN
  introMessage: Kursi mil gayi. Ab har order ko result, record aur public audit mein
    badalna hoga.
  objectives:
  - {fileID: 1827189462}
  - {fileID: 1168244966}
  - {fileID: 1564597409}
  - {fileID: 1946764460}
  - {fileID: 1478763917}
