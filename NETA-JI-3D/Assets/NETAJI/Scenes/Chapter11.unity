  m_EditorClassIdentifier: Assembly-CSharp::NetaJi.Prototype.MissionController
  missionTitle: Janata Ka MLA
  completionTitle: CHAPTER 11 COMPLETE
  completionMessage: Azad ne seat ko seva office aur accountable legislative record
    mein badla. Agla challenge district bhar ka network hai.
  chapterNumber: 11
  nextChapterScene: 
  introTitle: CHAPTER 11 / JANATA KA MLA
  introMessage: Seat ko power nahi, measurable constituency service aur legislative
    duty mein badlo.
  objectives:
  - {fileID: 1717160263}
  - {fileID: 181771172}
  - {fileID: 1308101269}
  - {fileID: 1391833336}
  - {fileID: 1451484241}
  - {fileID: 1649783713}
  - {fileID: 618654296}
  - {fileID: 1822895708}
  - {fileID: 315523835}
  - {fileID: 2073167762}
  - {fileID: 1918742755}
  - {fileID: 1874111027}
  objectiveLabels:
  - Fictional assembly registrar ke saamne public duty oath record karein
  - Token-based constituency office aur separate public allocation ledger kholein
  - Privacy-safe constituency case dashboard aur deadlines publish karein
  - Evidence-backed hospital procurement question assembly desk par file karein
  - Committee ko indexed evidence aur privacy-safe citizen statements dein
  - Student transport aur safe-stop allocation with outcomes approve karein
  - Open project scorecard ya closed recommendation list mein decision lein
  - Samrat ke saath non-partisan flood shelter and relief system activate karein
  - Whistleblower evidence ko independent protected channel mein seal karein
  - Attendance, questions, votes aur conflict declarations publish karein
  - Shanti ke saath open constituency report card and opposition Q&A karein
  - Independent panel par computed MLA performance review dekhein
  milestoneSteps: 03000000070000000a000000
  milestoneTitles:
  - CONSTITUENCY OFFICE LIVE
  - LEGISLATIVE RECORD ACTIVE
  - PUBLIC FUNDS TRACEABLE
  milestoneMessages:
  - Oath, public allocation and case dashboard live. Ab ground evidence assembly
    process mein le jaana hai.
  - Question, committee, budget and works decision recorded. Emergency response and
    ethics channel next hain.
  - Flood response, disclosure channel and attendance record complete. Citizen report
    card final review lock karega.
