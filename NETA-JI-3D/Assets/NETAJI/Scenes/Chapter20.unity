  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NetaJi.Prototype.MissionController
  missionTitle: Haar Ke Baad Himmat
  completionTitle: CHAPTER 20 COMPLETE
  completionMessage: Five saal ki responsible opposition, public service aur policy
    correction ke baad second national campaign approved hai. Haar ant nahi thi;
    public record agla raasta bana.
  chapterNumber: 20
  nextChapterScene: 
  introTitle: CHAPTER 20 / HAAR KE BAAD HIMMAT
  introMessage: Pehla national election haarne ke baad Azad paanch saal tak responsible
    opposition, seva aur policy alternatives ka public record banata hai.
  objectives:
  - {fileID: 433468024}
  - {fileID: 181786536}
  - {fileID: 630100974}
  - {fileID: 322768198}
  - {fileID: 1089918313}
  - {fileID: 698548813}
  - {fileID: 189180222}
  - {fileID: 586946758}
  - {fileID: 1656999991}
  - {fileID: 1936261463}
  - {fileID: 300038815}
  - {fileID: 691302600}
  objectiveLabels:
  - Count, concession, de-escalation and peaceful-transition record sign karein
  - Attendance, questions, committees, amendments and recusals publish karein
  - Paperwork, referral, school, health and helpline service network chalayein
  - Sourced critique ke saath costed alternatives aur corrections publish karein
  - Neutral flood relief, shared needs list and referral response coordinate karein
  - Documents, response rights, source protection and corrections defend karein
  - Issue-by-issue opposition ya constant confrontation mein decision lein
  - Shanti ke learning circles, civic forms aur scholarship network badhayein
  - Neutral safety, evidence handover aur emergency referral protocol verify karein
  - Regional language, leadership, consent aur opt-out charter renew karein
  - Promises, attendance, service, finance, complaints aur mistakes publish karein
  - Independent five-year review aur second-campaign eligibility dekhein
  milestoneSteps: 03000000070000000a000000
  milestoneTitles:
  - SEVA RECORD LIVE
  - OPPOSITION MODEL LOCKED
  - ALLIANCE RENEWED
  milestoneMessages:
  - Result acceptance, council accountability and public service record active hain.
    Policy alternatives aur relief next hain.
  - Evidence watchdog aur five-year approach complete hain. Shanti, Samrat and regional
    partners next hain.
  - Public learning, neutral institutions and regional autonomy verified hain. Five-year
    report review unlock karega.
