  missionTitle: Operation Umeed
  completionTitle: CHAPTER 4 COMPLETE
  completionMessage: Sandhya safe hai. Evidence police custody mein hai aur family
    saath hai.
  chapterNumber: 4
  nextChapterScene: Chapter05
  introTitle: CHAPTER 4 / OPERATION UMEED
  introMessage: Riverside godown. Sandhya ki safety pehle; gussa aur jaldbazi baad
    mein.
  objectives:
  - {fileID: 960852492}
  - {fileID: 1104143675}
  - {fileID: 89871103}
  - {fileID: 1478056932}
  - {fileID: 1104584853}
  - {fileID: 1003603105}
  - {fileID: 1875009864}
  - {fileID: 664452633}
  - {fileID: 2055227893}
  - {fileID: 2076264735}
  - {fileID: 351856060}
  objectiveLabels:
  - Constable Samrat se perimeter briefing lein
  - CCTV clue se suspect van verify karein
  - Sandhya ki watch ka short-range signal lock karein
  - Rescue ke liye coordinated ya solo approach chunein
  - Samrat ke saath side gate safely unlock karein
  - Patrol aur medical team ko entry signal bhejein
  - Side office mein Sandhya tak pahunchein
  - Sandhya ko basic first aid aur paani dein
  - Samrat ke liye payment ledger evidence secure karein
  - Police evidence handover record complete karein
  - Family safe point par Shanti se milen
  milestoneSteps: 030000000600000008000000
  milestoneTitles:
  - LOCATION CONFIRMED
  - ENTRY READY
  - SANDHYA SAFE
  milestoneMessages:
  - Van aur watch signal match karte hain. Ab rescue approach decide karna hai.
  - Gate aur patrol signal ready hain. Samrat ki team ke saath side office tak pahuncho.
  - Sandhya mil gayi hai. First aid ke baad evidence secure karna hoga.
