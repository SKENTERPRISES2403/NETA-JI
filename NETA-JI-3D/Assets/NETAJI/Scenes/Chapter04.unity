  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NetaJi.Prototype.MissionObjective
  objectiveId: rescue-decision
  prompt: Rescue approach chunein
  speaker: Azad
  dialogue: Samrat, perimeter aur backup ke saath chalenge. Sandhya ki safety mere
    ego se badi hai.
  trustReward: 3
  moneyReward: -100
  reputationReward: 3
  proofReward: 0
  hideAfterCompletion: 0
  requiresDecision: 1
  decisionKey: rescue-approach
  decisionTitle: RESCUE APPROACH
  decisionMessage: Backup bas kuch minute door hai. Coordinated entry safer hai;
    solo entry tez lag sakti hai, par Sandhya aur team dono ko risk hoga.
  firstOption: 'SAMRAT KA PLAN

    Funds -100 / Trust +3'
  secondOption: 'AKELA SIDE GATE

    Trust -4 / Rep -3'
  secondDialogue: Azad akela side gate tak badhta hai. Alarm trigger hota hai aur
    Samrat ko team jaldi move karni padti hai.
  secondTrustReward: -4
  secondMoneyReward: 0
  secondReputationReward: -3
  secondProofReward: 0
