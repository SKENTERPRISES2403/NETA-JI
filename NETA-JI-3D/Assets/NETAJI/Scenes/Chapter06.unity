  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NetaJi.Prototype.MissionObjective
  objectiveId: opposition-response
  prompt: Opposition response chunein
  speaker: Azad
  dialogue: Audit, receipts aur independent questions ke saath open jan-samvad karenge.
    Awaaz kam, saboot zyada.
  trustReward: 2
  moneyReward: -100
  reputationReward: 3
  proofReward: 3
  powerReward: 3
  volunteerReward: 8
  pressureReward: 3
  hideAfterCompletion: 0
  requiresDecision: 1
  decisionKey: opposition-response
  decisionTitle: FIRST OPPOSITION TEST
  decisionMessage: Anonymous rumour viral ho raha hai. Documented public dialogue
    slow hai; direct confrontation tez, par pressure badha sakta hai.
  firstOption: 'OPEN JAN-SAMVAD

    Proof +3 / Pressure +3'
  secondOption: 'DIRECT CONFRONTATION

    Power +5 / Pressure +12'
  secondDialogue: Azad rival meeting ke bahar direct jawab deta hai. Core supporters
    energize hote hain, par conflict aur pressure dono badhte hain.
  secondTrustReward: 3
  secondMoneyReward: 0
  secondReputationReward: -4
  secondProofReward: -2
  secondPowerReward: 5
  secondVolunteerReward: 5
  secondPressureReward: 12
