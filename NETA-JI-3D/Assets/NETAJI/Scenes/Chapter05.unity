  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NetaJi.Prototype.MissionController
  missionTitle: Dawa Ka Sach
  completionTitle: CHAPTER 5 COMPLETE
  completionMessage: Shanti stable hai. Verified healthcare case file ne Azad ke
    system-change sankalp ko janam diya.
  chapterNumber: 5
  nextChapterScene: Chapter06
  introTitle: CHAPTER 5 / DAWA KA SACH
  introMessage: Rescue ke baad ek nayi emergency. Shanti ki jaan, documents aur sach
    tino sambhalo.
  objectives:
  - {fileID: 1863156012}
  - {fileID: 1544331483}
  - {fileID: 870351549}
  - {fileID: 732026942}
  - {fileID: 571916051}
  - {fileID: 357265745}
  - {fileID: 891935246}
  - {fileID: 1790877137}
  - {fileID: 2104385685}
  - {fileID: 1280572924}
  - {fileID: 911850152}
  - {fileID: 453839675}
  objectiveLabels:
  - Shanti ki emergency condition samjhein
  - Emergency transport aur receipt confirm karein
  - Triage desk par Shanti ki medical history dein
  - Emergency consent ko padhkar signed copy lein
  - Helpers Hand verified donor network activate karein
  - Pharmacy stock register aur issue time verify karein
  - Medicine batch label aur invoice mismatch preserve karein
  - Duty doctor se private medical update lein
  - Verified case file ya instant public post chunein
  - Records office se certified tender copy lein
  - Samrat ke saath healthcare evidence chain complete karein
  - Recovery garden mein Shanti ke saath agla kadam tay karein
  milestoneSteps: 05000000080000000b000000
  milestoneTitles:
  - EMERGENCY SUPPORT READY
  - DIFFICULT TRUTH
  - CASE FILE SEALED
  milestoneMessages:
  - Transport, triage, consent aur donors ready hain. Ab pharmacy records verify
    karo.
  - Shanti stable hai, par family ne pregnancy kho di. Gusse ko verified case mein
    badalna hoga.
  - Tender aur medicine evidence sealed hai. Recovery garden mein Shanti intezar
    kar rahi hai.
