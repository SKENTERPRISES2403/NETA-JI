  objectiveId: hospital-decision
  prompt: Case strategy chunein
  speaker: Azad
  dialogue: Pehle batch, stock aur tender file verify karenge. Sach dheere chale,
    par adhoora nahi.
  trustReward: 2
  moneyReward: -100
  reputationReward: 3
  proofReward: 5
  powerReward: 0
  volunteerReward: 0
  pressureReward: 0
  hideAfterCompletion: 0
  requiresDecision: 1
  decisionKey: hospital-approach
  decisionTitle: CASE STRATEGY
  decisionMessage: Supplier ka naam abhi post karna tez pressure banayega, par unverified
    claim case ko kamzor kar sakta hai.
  firstOption: 'VERIFIED CASE FILE

    Rs -100 / Proof +5'
  secondOption: 'ABHI PUBLIC POST

    Trust +4 / Rep -4'
  secondDialogue: Azad supplier list turant post karta hai. Public pressure badhta
    hai, par incomplete proof se official case weak hota hai.
  secondTrustReward: 4
  secondMoneyReward: 0
  secondReputationReward: -4
  secondProofReward: -3
  secondPowerReward: 0
  secondVolunteerReward: 0
  secondPressureReward: 0
