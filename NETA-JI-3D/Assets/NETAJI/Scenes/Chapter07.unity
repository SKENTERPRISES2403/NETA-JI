  objectiveId: campaign-strategy
  prompt: Final campaign strategy chunein
  speaker: Azad
  dialogue: Chhoti issue meetings aur door-to-door fact sheets. Kam shor, zyada booth
    discipline.
  trustReward: 0
  moneyReward: -200
  reputationReward: 2
  proofReward: 2
  powerReward: 2
  volunteerReward: 5
  pressureReward: 2
  supportReward: 12
  boothReward: 10
  resolvesWardElection: 0
  hideAfterCompletion: 0
  requiresDecision: 1
  decisionKey: campaign-strategy
  decisionTitle: FINAL CAMPAIGN STRATEGY
  decisionMessage: Ground meetings costly aur slow hain. Mega rally tez support la
    sakti hai, par booth discipline aur pressure ko hurt karegi.
  firstOption: 'GROUND CAMPAIGN

    Support +12 / Booth +10'
  secondOption: 'MEGA RALLY

    Support +16 / Pressure +10'
  secondDialogue: Campaign mega rally par shift hota hai. Crowd bada hai, par expense
    scrutiny aur booth coordination weak hoti hai.
  secondTrustReward: 0
  secondMoneyReward: -50
  secondReputationReward: -3
  secondProofReward: -2
