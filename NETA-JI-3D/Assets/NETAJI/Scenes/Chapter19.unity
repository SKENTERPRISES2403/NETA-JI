  missionTitle: Pehla Rashtriya Faisla
  completionTitle: CHAPTER 19 COMPLETE
  completionMessage: 49% vote aur 42/100 fictional seats. Pehla national mandate
    nahi mila. Azad result sweekar karke responsible opposition aur public service
    ka sankalp leta hai.
  chapterNumber: 19
  nextChapterScene: 
  introTitle: CHAPTER 19 / PEHLA RASHTRIYA FAISLA
  introMessage: National stage par seva ka record zaroori hai, lekin pehli baar mein
    mandate milna guaranteed nahi.
  objectives:
  - {fileID: 1730046254}
  - {fileID: 532171687}
  - {fileID: 334693610}
  - {fileID: 1717817612}
  - {fileID: 1133153307}
