  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NetaJi.Prototype.MissionController
  missionTitle: Pehla Rashtriya Faisla
  completionTitle: CHAPTER 19 COMPLETE
  completionMessage: 49% vote aur 42/100 fictional seats. Pehla national mandate
    nahi mila. Azad result sweekar karke responsible opposition aur public service
    ka sankalp leta hai.
  chapterNumber: 19
  nextChapterScene: 
  introTitle: CHAPTER 19 / PEHLA RASHTRIYA FAISLA
  introMessage: National stage par seva ka record zaroori hai, lekin pehli baar mein
    mandate milna guaranteed nahi.
  objectives:
  - {fileID: 1192681967}
  - {fileID: 709894428}
  - {fileID: 1903707154}
  - {fileID: 2000963198}
  - {fileID: 1501564992}
  - {fileID: 1567924826}
  - {fileID: 1023721542}
  - {fileID: 493631968}
  - {fileID: 342095362}
  - {fileID: 838760515}
  - {fileID: 2077276445}
  - {fileID: 818117185}
  objectiveLabels:
  - Nomination, endorsements, disclosures and deadlines verify karein
  - Cost, timeline, limits and corrections ke saath manifesto publish karein
  - Candidate disclosure, conflict, interview and appeal records check karein
  - Multilingual, easy-read and accessible campaign media run karein
  - Small meetings, listening cards and consent-based follow-up yatra run karein
  - Equal-time sourced debate aur correction window complete karein
  - Issue-first federation ya spectacle convoy mein decision lein
  - Sources, caps, media invoices and vendor conflicts audit karein
  - Queue, accessibility, observer and result-form operations train karein
  - Neutral emergency, queue and evidence-handover safety drill karein
  - Corrections, promotion pause and result-acceptance statement activate karein
  - Independent 100-seat fictional national count aur result dekhein
  milestoneSteps: 03000000070000000a000000
  milestoneTitles:
  - CLEAN SLATE READY
  - CAMPAIGN MODEL LOCKED
  - POLL SYSTEM READY
  milestoneMessages:
  - Eligibility, manifesto and candidate slate verified. Language access and yatra
    next hain.
  - Language, ground yatra, debate and campaign strategy ready. Funding and polling
    operations next hain.
  - Funding, poll operations and neutral safety verified. Silence protocol final
    count unlock karega.
