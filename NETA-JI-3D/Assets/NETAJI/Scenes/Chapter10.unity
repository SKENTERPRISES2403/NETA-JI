  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NetaJi.Prototype.MissionController
  missionTitle: Janata Ka Mandate
  completionTitle: CHAPTER 10 COMPLETE
  completionMessage: Constituency ne record, organization aur lawful campaign ko
    vote diya. Azad ka MLA safar ab shuru hota hai.
  chapterNumber: 10
  nextChapterScene: 
  introTitle: CHAPTER 10 / JANATA KA MANDATE
  introMessage: Candidate bano, lawful campaign chalao aur Vidhansabha ka result
    earn karo.
  objectives:
  - {fileID: 2102743668}
  - {fileID: 1117304996}
  - {fileID: 287819368}
  - {fileID: 1791228645}
  - {fileID: 1296406812}
  - {fileID: 2051624597}
  - {fileID: 597327585}
  - {fileID: 272455350}
  - {fileID: 2064202693}
  - {fileID: 279203437}
  - {fileID: 2019969213}
  - {fileID: 377495837}
  objectiveLabels:
  - Independent trainer ke saamne lawful candidacy pledge sign karein
  - Five measurable promises ka cost aur funding source publish karein
  - Rural padyatra mein issue logs aur follow-up dockets complete karein
  - Shanti ke saath women-youth led urban town hall complete karein
  - Volunteer batch ko consent, spending aur anti-hate rules train karein
  - Edited rumour ka source-backed correction publish karein
  - Equal-time public debate mein records aur costed plan defend karein
  - Disciplined issue yatra ya influencer-led mega convoy mein decision lein
  - Donation, print, vehicle aur digital spending audit close karein
  - Neutral polling zone ka accessibility aur queue plan verify karein
  - Samrat se neutral polling perimeter aur complaint protocol confirm karein
  - Independent observer se computed Vidhansabha result receive karein
  milestoneSteps: 03000000070000000a000000
  milestoneTitles:
  - COSTED MANIFESTO LIVE
  - CAMPAIGN RULES LOCKED
  - POLLING SYSTEM READY
  milestoneMessages:
  - Nomination, costed manifesto aur rural issue route complete. Urban public dialogue
    next hai.
  - Town halls, volunteer training, fact-check aur debate verified. Final campaign
    strategy ab consequences set karegi.
  - Strategy and accounts audited. Accessible polling plan aur neutral perimeter
    ke baad counting hogi.
