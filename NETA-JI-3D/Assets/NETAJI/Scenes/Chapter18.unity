  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NetaJi.Prototype.MissionController
  missionTitle: Desh Bhar Ka Saath
  completionTitle: CHAPTER 18 COMPLETE
  completionMessage: 18 fictional regional chapters align hue. National election
    ki taiyari ab publicity nahi, accountable federation ke roop mein shuru hogi.
  chapterNumber: 18
  nextChapterScene: 
  introTitle: CHAPTER 18 / DESH BHAR KA SAATH
  introMessage: Ek state ka model national tab banta hai jab doosre regions usse
    copy nahi, apni awaaz ke saath shape karein.
  objectives:
  - {fileID: 726956040}
  - {fileID: 1037481906}
  - {fileID: 128833736}
  - {fileID: 1174725834}
  - {fileID: 487535635}
  - {fileID: 2139176862}
  - {fileID: 356638700}
  - {fileID: 1823924289}
  - {fileID: 1040220916}
  - {fileID: 1935178743}
  - {fileID: 1363029065}
  - {fileID: 326205786}
  objectiveLabels:
  - State outcomes, disclosures and correction record verify karein
  - Regional autonomy, membership, elections and appeal rules publish karein
  - 18 fictional regions mein local priorities aur language access listen karein
  - Disclosure, conflict check, interview and removal appeal standard lock karein
  - Fact-check, consent, safety and grievance training federation build karein
  - Shanti ke saath multilingual and accessible participation charter banayein
  - Patient federation ya centralized headline wave mein decision lein
  - Regional evidence ke saath health, learning, safety and livelihood platform publish
    karein
  - Donation caps, source checks, expense ledger and vendor conflicts audit karein
  - Samrat ke saath event safety, emergency and missing-person drill karein
  - Regional votes, dissent notes and policy amendments ke saath convention conduct
    karein
  - Reach, alliance trust, policy credibility and regional alignment ka review dekhein
  milestoneSteps: 03000000070000000a000000
  milestoneTitles:
  - FEDERAL RULES READY
  - NATIONAL STRATEGY LOCKED
  - TRUST NETWORK ACTIVE
  milestoneMessages:
  - Eligibility, federal rules and regional listening verified. Ethics and training
    next hain.
  - Candidate ethics, volunteer training, language access and expansion strategy
    active hain. Policy and funding next hai.
  - Policy, clean funding and convention safety verified. Open convention final review
    unlock karega.
